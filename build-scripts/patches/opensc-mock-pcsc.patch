+/* Mock PC/SC for fuzzing */
+typedef struct {
+	const char *name;
+	const uint8_t atr[33];
+	size_t atr_len;
+} mock_reader_info_t;
+
+static const mock_reader_info_t MOCK_READERS[] = {
+	{"Mock PIV", {0x3b, 0x7f, 0x96, 0x00, 0x00, 0x80, 0x31, 0x80, 0x65, 0xb0, 0x85, 0x59, 0x3d, 0xb0, 0x2f, 0x1f, 0x00, 0x00, 0x00}, 19},
