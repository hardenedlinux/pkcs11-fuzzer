+	{"Mock Itacns", {0x3b, 0xf4, 0x18, 0x00, 0xff, 0x81, 0x31, 0x80, 0x55, 0x00, 0x31, 0x80, 0x00, 0xc7}, 14},
+	{"Mock OpenPGP", {0x3B, 0xDA, 0x18, 0xFF, 0x81, 0xB1, 0xFE, 0x75, 0x1F, 0x03, 0x00, 0x31, 0xC5, 0x73, 0xC0, 0x01, 0x40, 0x00, 0x90, 0x00, 0x0C}, 21},
+	{"Mock ePass2003", {0x3B, 0x9F, 0x95, 0x81, 0x31, 0xFE, 0x9F, 0x00, 0x66, 0x46, 0x53, 0x05, 0x01, 0x00, 0x11, 0x71, 0xDF, 0x00, 0x00, 0x03, 0x90, 0x00, 0x80}, 23},
+	{"Mock Belpic", {0x3B, 0x7F, 0x96, 0x00, 0x00, 0x80, 0x31, 0x80, 0x65, 0xB0, 0x85, 0x04, 0x01, 0x20, 0x12, 0x0F, 0xFF, 0x82, 0x90, 0x00}, 20},
+	{"Mock EstEID", {0x3b, 0xdb, 0x96, 0x00, 0x80, 0xb1, 0xfe, 0x45, 0x1f, 0x83, 0x00, 0x12, 0x23, 0x3f, 0x53, 0x65, 0x49, 0x44, 0x0f, 0x90, 0x00, 0xf1}, 22}
+};
+#define NUM_MOCK_READERS (sizeof(MOCK_READERS) / sizeof(MOCK_READERS[0]))
+
+static LONG PCSC_API SCardEstablishContext_mock(DWORD dwScope, LPCVOID pvReserved1, LPCVOID pvReserved2, LPSCARDCONTEXT phContext) {
+	if (phContext) *phContext = 1;
+	return SCARD_S_SUCCESS;
+}
+static LONG PCSC_API SCardReleaseContext_mock(SCARDCONTEXT hContext) { return SCARD_S_SUCCESS; }
+static LONG PCSC_API SCardListReaders_mock(SCARDCONTEXT hContext, LPCSTR mszGroups, LPSTR mszReaders, LPDWORD pcchReaders) {
+	size_t total_len = 0;
+	for (size_t i = 0; i < NUM_MOCK_READERS; i++) total_len += strlen(MOCK_READERS[i].name) + 1;
+	total_len++; /* final null */
+
+	if (!mszReaders) { *pcchReaders = (DWORD)total_len; return SCARD_S_SUCCESS; }
+	if (*pcchReaders < total_len) return SCARD_E_INSUFFICIENT_BUFFER;
+	
+	char *p = mszReaders;
+	for (size_t i = 0; i < NUM_MOCK_READERS; i++) {
+		strcpy(p, MOCK_READERS[i].name);
+		p += strlen(MOCK_READERS[i].name) + 1;
+	}
+	*p = '\0';
+	*pcchReaders = (DWORD)total_len;
+	return SCARD_S_SUCCESS;
+}
+static LONG PCSC_API SCardGetStatusChange_mock(SCARDCONTEXT hContext, DWORD dwTimeout, SCARD_READERSTATE *rgReaderStates, DWORD cReaders) {
+	for (DWORD i=0; i<cReaders; i++) {
+		rgReaderStates[i].dwEventState = SCARD_STATE_PRESENT | SCARD_STATE_CHANGED;
+		for (size_t j = 0; j < NUM_MOCK_READERS; j++) {
+			if (rgReaderStates[i].szReader && strcmp(rgReaderStates[i].szReader, MOCK_READERS[j].name) == 0) {
+				rgReaderStates[i].cbAtr = (DWORD)MOCK_READERS[j].atr_len;
+				memcpy(rgReaderStates[i].rgbAtr, MOCK_READERS[j].atr, MOCK_READERS[j].atr_len);
+				break;
+			}
+		}
+	}
+	return SCARD_S_SUCCESS;
+}
+static LONG PCSC_API SCardConnect_mock(SCARDCONTEXT hContext, LPCSTR szReader, DWORD dwShareMode, DWORD dwPreferredProtocols, LPSCARDHANDLE phCard, LPDWORD pdwActiveProtocol) {
+	for (size_t i = 0; i < NUM_MOCK_READERS; i++) {
+		if (szReader && strcmp(szReader, MOCK_READERS[i].name) == 0) {
+			if (phCard) *phCard = (SCARDHANDLE)(i + 1);
+			if (pdwActiveProtocol) *pdwActiveProtocol = SCARD_PROTOCOL_T1;
+			return SCARD_S_SUCCESS;
+		}
+	}
+	return SCARD_E_UNKNOWN_READER;
+}
+static LONG PCSC_API SCardStatus_mock(SCARDHANDLE hCard, LPSTR mszReaderNames, LPDWORD pcchReaderLen, LPDWORD pdwState, LPDWORD pdwProtocol, LPBYTE pbAtr, LPDWORD pcbAtrLen) {
+	size_t idx = (size_t)(hCard - 1);
+	if (idx >= NUM_MOCK_READERS) return SCARD_E_INVALID_HANDLE;
+	if (pdwState) *pdwState = SCARD_STATE_PRESENT;
+	if (pdwProtocol) *pdwProtocol = SCARD_PROTOCOL_T1;
+	if (pbAtr) {
+		if (*pcbAtrLen < MOCK_READERS[idx].atr_len) return SCARD_E_INSUFFICIENT_BUFFER;
+		memcpy(pbAtr, MOCK_READERS[idx].atr, MOCK_READERS[idx].atr_len);
+	}
+	if (pcbAtrLen) *pcbAtrLen = (DWORD)MOCK_READERS[idx].atr_len;
+	return SCARD_S_SUCCESS;
+}
+static LONG PCSC_API SCardTransmit_mock(SCARDHANDLE hCard, LPCSCARD_IO_REQUEST pioSendPci, LPCBYTE pbSendBuffer, DWORD cbSendLength, LPSCARD_IO_REQUEST pioRecvPci, LPBYTE pbRecvBuffer, LPDWORD pcbRecvLength) {
+	if (*pcbRecvLength < 2) return SCARD_E_INSUFFICIENT_BUFFER;
+	pbRecvBuffer[0] = 0x90; pbRecvBuffer[1] = 0x00; *pcbRecvLength = 2;
+	return SCARD_S_SUCCESS;
+}
+static LONG PCSC_API SCardControl_mock(SCARDHANDLE hCard, DWORD dwControlCode, LPCVOID pbSendBuffer, DWORD cbSendLength, LPVOID pbRecvBuffer, DWORD cbRecvLength, LPDWORD lpBytesReturned) {
+	if (lpBytesReturned) *lpBytesReturned = 0;
+	return SCARD_S_SUCCESS;
+}
+static LONG PCSC_API SCardBeginTransaction_mock(SCARDHANDLE hCard) { return SCARD_S_SUCCESS; }
+static LONG PCSC_API SCardEndTransaction_mock(SCARDHANDLE hCard, DWORD dwDisposition) { return SCARD_S_SUCCESS; }
+static LONG PCSC_API SCardReconnect_mock(SCARDHANDLE hCard, DWORD dwShareMode, DWORD dwPreferredProtocols, DWORD dwInitialization, LPDWORD pdwActiveProtocol) { return SCARD_S_SUCCESS; }
+static LONG PCSC_API SCardDisconnect_mock(SCARDHANDLE hCard, DWORD dwDisposition) { return SCARD_S_SUCCESS; }
+static LONG PCSC_API SCardCancel_mock(SCARDCONTEXT hContext) { return SCARD_S_SUCCESS; }
+static LONG PCSC_API SCardGetAttrib_mock(SCARDHANDLE hCard, DWORD dwAttrId, LPBYTE pbAttr, LPDWORD pcbAttrLen) { return SCARD_E_INVALID_HANDLE; }
+
+static int pcsc_install_mock(struct pcsc_global_private_data *gpriv) {
+	const char *env = getenv("OPENSC_MOCK_PCSC");
+	if (!env || strcmp(env, "1") != 0) return 0;
+	fprintf(stderr, "[libopensc] Mock PC/SC driver installed with %lu readers\n", (unsigned long)NUM_MOCK_READERS);
+	gpriv->SCardEstablishContext = SCardEstablishContext_mock;
+	gpriv->SCardReleaseContext = SCardReleaseContext_mock;
+	gpriv->SCardConnect = SCardConnect_mock;
+	gpriv->SCardReconnect = SCardReconnect_mock;
+	gpriv->SCardDisconnect = SCardDisconnect_mock;
+	gpriv->SCardBeginTransaction = SCardBeginTransaction_mock;
+	gpriv->SCardEndTransaction = SCardEndTransaction_mock;
+	gpriv->SCardStatus = SCardStatus_mock;
+	gpriv->SCardGetStatusChange = SCardGetStatusChange_mock;
+	gpriv->SCardCancel = SCardCancel_mock;
+	gpriv->SCardTransmit = SCardTransmit_mock;
+	gpriv->SCardListReaders = SCardListReaders_mock;
+	gpriv->SCardControl = SCardControl_mock;
+	gpriv->SCardGetAttrib = SCardGetAttrib_mock;
+	return 1;
+}
